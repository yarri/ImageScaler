{
        "name": "pupiq/image-scaler",
        "type": "library",
        "description": "PHP library for image resizing, cropping and format conversion. Supports JPEG, PNG, animated GIF, WebP, AVIF and HEIC.",
        "keywords": ["image","resize","scale","watermark"],
        "homepage": "https://github.com/yarri/ImageScaler",
        "license": ["MIT"],
        "authors": [
                {
                        "name": "Jaromir Tomek",
                        "homepage": "https://github.com/yarri"
                }
        ],
        "require": {
                "php": ">=7.4",
                "ext-imagick": ">=3.4",
                "atk14/files": "1.* >=1.3.1",
                "sybio/gif-frame-extractor": "^1.0",
                "yarri/gif-creator": "^1.0"
        },
        "require-dev": {
                "atk14/tester": "*"
        },
        "autoload": {
                "classmap": ["src"]
        }
}
